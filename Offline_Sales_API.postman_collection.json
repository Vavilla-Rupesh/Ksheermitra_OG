{
  "info": {
    "name": "Offline Sales API",
    "description": "API collection for testing In-Store (Offline) Sales feature",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_JWT_TOKEN",
      "type": "string"
    },
    {
      "key": "productId1",
      "value": "UUID_OF_PRODUCT_1",
      "type": "string"
    },
    {
      "key": "productId2",
      "value": "UUID_OF_PRODUCT_2",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Offline Sales",
      "item": [
        {
          "name": "1. Create Offline Sale",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"quantity\": 5\n    },\n    {\n      \"productId\": \"{{productId2}}\",\n      \"quantity\": 2\n    }\n  ],\n  \"customerName\": \"John Doe\",\n  \"customerPhone\": \"+919876543210\",\n  \"paymentMethod\": \"cash\",\n  \"notes\": \"Walk-in customer, paid in full\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"]
            },
            "description": "Create a new offline sale with multiple products. Stock will be reduced automatically and amount added to daily invoice."
          },
          "response": []
        },
        {
          "name": "2. Create Sale - Cash Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"quantity\": 3\n    }\n  ],\n  \"paymentMethod\": \"cash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"]
            },
            "description": "Create a sale without customer details (anonymous walk-in customer)"
          },
          "response": []
        },
        {
          "name": "3. Create Sale - UPI Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"quantity\": 10\n    }\n  ],\n  \"customerName\": \"Jane Smith\",\n  \"customerPhone\": \"+919123456789\",\n  \"paymentMethod\": \"upi\",\n  \"notes\": \"Paid via Google Pay\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"]
            },
            "description": "Create a sale with UPI payment method"
          },
          "response": []
        },
        {
          "name": "4. Get All Offline Sales",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"]
            },
            "description": "Get all offline sales with default pagination (50 per page)"
          },
          "response": []
        },
        {
          "name": "5. Get Sales - With Pagination",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get offline sales with custom pagination"
          },
          "response": []
        },
        {
          "name": "6. Get Sales - By Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales?startDate=2026-01-01&endDate=2026-01-31",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-01-31"
                }
              ]
            },
            "description": "Get sales for a specific date range"
          },
          "response": []
        },
        {
          "name": "7. Get Sales - Today Only",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales?startDate=2026-01-04&endDate=2026-01-04",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-01-04",
                  "description": "Replace with today's date"
                },
                {
                  "key": "endDate",
                  "value": "2026-01-04",
                  "description": "Replace with today's date"
                }
              ]
            },
            "description": "Get today's offline sales only"
          },
          "response": []
        },
        {
          "name": "8. Get Sale by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales/:saleId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales", ":saleId"],
              "variable": [
                {
                  "key": "saleId",
                  "value": "SALE_UUID_HERE"
                }
              ]
            },
            "description": "Get detailed information about a specific sale"
          },
          "response": []
        },
        {
          "name": "9. Get Sales Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales/stats",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales", "stats"]
            },
            "description": "Get overall sales statistics (total sales, revenue, average)"
          },
          "response": []
        },
        {
          "name": "10. Get Stats - By Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/offline-sales/stats?startDate=2026-01-01&endDate=2026-01-31",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offline-sales", "stats"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-01-31"
                }
              ]
            },
            "description": "Get sales statistics for a specific date range"
          },
          "response": []
        },
        {
          "name": "11. Get Admin Daily Invoice",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/invoices/admin-daily?date=2026-01-04",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "invoices", "admin-daily"],
              "query": [
                {
                  "key": "date",
                  "value": "2026-01-04",
                  "description": "Date in YYYY-MM-DD format"
                }
              ]
            },
            "description": "Get the admin daily invoice with all offline sales for a specific date"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products (for reference)",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/products",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products"]
            },
            "description": "Get all products to find product IDs for testing"
          },
          "response": []
        }
      ]
    }
  ]
}

