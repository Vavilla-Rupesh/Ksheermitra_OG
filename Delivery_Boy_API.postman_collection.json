{
  "info": {
    "name": "Ksheer Mitra - Delivery Boy API",
    "description": "Complete API collection for Delivery Boy module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{delivery_boy_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "delivery_boy_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "delivery_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/send-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "send-otp"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.environment.set('delivery_boy_token', jsonData.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Delivery Boy",
      "item": [
        {
          "name": "Get Delivery Map (Today)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/delivery-map",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "delivery-map"]
            }
          }
        },
        {
          "name": "Get Delivery Map (Specific Date)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/delivery-map?date=2025-11-02",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "delivery-map"],
              "query": [
                {
                  "key": "date",
                  "value": "2025-11-02"
                }
              ]
            }
          }
        },
        {
          "name": "Generate Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-11-02\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/delivery-boy/generate-invoice",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "generate-invoice"]
            }
          }
        },
        {
          "name": "Get Delivery History (Default)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/history",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "history"]
            }
          }
        },
        {
          "name": "Get Delivery History (With Pagination)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/history?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "history"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Delivery History (Date Range)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/history?startDate=2025-11-01&endDate=2025-11-02",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "history"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2025-11-01"
                },
                {
                  "key": "endDate",
                  "value": "2025-11-02"
                }
              ]
            }
          }
        },
        {
          "name": "Get Stats (All Time)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/stats",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "stats"]
            }
          }
        },
        {
          "name": "Get Stats (Today)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/stats?period=today",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "stats"],
              "query": [
                {
                  "key": "period",
                  "value": "today"
                }
              ]
            }
          }
        },
        {
          "name": "Get Stats (This Week)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/stats?period=week",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "stats"],
              "query": [
                {
                  "key": "period",
                  "value": "week"
                }
              ]
            }
          }
        },
        {
          "name": "Get Stats (This Month)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/stats?period=month",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "stats"],
              "query": [
                {
                  "key": "period",
                  "value": "month"
                }
              ]
            }
          }
        },
        {
          "name": "Update Delivery Status (In Progress)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"notes\": \"Started delivery\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            },
            "url": {
              "raw": "{{base_url}}/delivery-boy/delivery/{{delivery_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "delivery", "{{delivery_id}}", "status"]
            }
          }
        },
        {
          "name": "Update Delivery Status (Delivered)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"delivered\",\n  \"notes\": \"Delivered successfully to customer\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            },
            "url": {
              "raw": "{{base_url}}/delivery-boy/delivery/{{delivery_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "delivery", "{{delivery_id}}", "status"]
            }
          }
        },
        {
          "name": "Update Delivery Status (Failed)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"failed\",\n  \"notes\": \"Customer not available\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/delivery-boy/delivery/{{delivery_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "delivery", "{{delivery_id}}", "status"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delivery-boy/profile",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "profile"]
            }
          }
        },
        {
          "name": "Update Location",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            },
            "url": {
              "raw": "{{base_url}}/delivery-boy/location",
              "host": ["{{base_url}}"],
              "path": ["delivery-boy", "location"]
            }
          }
        }
      ]
    }
  ]
}

